{
  "type": "data",
  "name": "InitDisklessLogRequestData",
  "validVersions": "0",
  "flexibleVersions": "0+",
  "fields": [
    { "name": "BrokerId", "type": "int32", "versions": "0+",
      "about": "The broker ID of the requesting leader." },
    { "name": "BrokerEpoch", "type": "int64", "versions": "0+", "default": "-1",
      "about": "The epoch of the requesting broker." },
    { "name": "Topics", "type": "[]TopicData", "versions": "0+",
      "about": "The topics to initialize as diskless.", "fields": [
      { "name": "TopicId", "type": "uuid", "versions": "0+",
        "about": "The topic ID." },
      { "name": "Partitions", "type": "[]PartitionData", "versions": "0+",
        "about": "The partitions to initialize as diskless.", "fields": [
        { "name": "PartitionId", "type": "int32", "versions": "0+",
          "about": "The partition ID." },
        { "name": "DisklessStartOffset", "type": "int64", "versions": "0+",
          "about": "The first offset retained for diskless reads." },
        { "name": "LeaderEpoch", "type": "int32", "versions": "0+",
          "about": "The leader epoch seen by the broker." },
        { "name": "ProducerStates", "type": "[]ProducerState", "versions": "0+",
